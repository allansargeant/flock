{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flock",
  "version": "0.1.0",
  "identifier": "com.allansargeant.flock",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "flock",
        "width": 460,
        "height": 500,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "resources": [
      "launcher.toml",
      "bin/flock",
      "bin/server-config.toml"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
